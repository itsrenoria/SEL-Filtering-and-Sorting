[
  {
    "expression": "/*Part of Tamtaro SEL Setup*/[]",
    "enabled": true
  },
  {
    "expression": "/*ISE v1.1.1*/[]",
    "enabled": true
  },
  {
    "expression": "/*git.tamtaro.de*/[]",
    "enabled": true
  },
  {
    "expression": "/*SeaDex*/merge(count(addon(cached(streams),'SeaDex'))>0?passthrough(addon(streams,'SeaDex'),'title','year'):passthrough(seadex(streams),'filter','title','year'),queryType=='anime.movie'?passthrough(seadex(streams),'episode'):[])",
    "enabled": true
  },
  {
    "expression": "/*Library*/count(streams)==count(library(streams))?library(streams):[]",
    "enabled": true
  },
  {
    "expression": "/*digitalRelease*/queryType=='movie' or queryType=='anime.movie'?passthrough(quality(streams,'CAM','TS','TC','SCR'),'digitalRelease') : []",
    "enabled": true
  },
  {
    "expression": "/*0Cached*/count(cached(streams))==0?passthrough(negate(type(streams,'usenet','stremio-usenet'),(streams)),'title'):[]",
    "enabled": true
  }
]